# Server Configuration
PORT=3001
NODE_ENV=development

# Database - Production MongoDB
# Replace with your MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Authentication
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Firebase
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_PROJECT_ID=freelancing-platform-v2
FIREBASE_AUTH_DOMAIN=freelancing-platform-v2.firebaseapp.com
FIREBASE_STORAGE_BUCKET=freelancing-platform-v2.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=713504655146
FIREBASE_APP_ID=1:713504655146:web:1d73bc6ffcdb61a8938053

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_BASE_URL=https://res.cloudinary.com/your_cloud_name
CLOUDINARY_UPLOAD_URL=https://api.cloudinary.com/v1_1/your_cloud_name

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,https://freelancing-platform-backend-backup.onrender.com

# Cashfree Payment Gateway
CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret
CASHFREE_API_VERSION=2023-08-01
CASHFREE_ENV=production
BACKEND_URL=https://freelancing-platform-backend-backup.onrender.com

# Cashfree Payouts V2 (x-client-id / x-client-secret on api.cashfree.com/payout — v1 APIs deprecated)
CASHFREE_PAYOUTS_ENV=production
CASHFREE_PAYOUTS_CLIENT_ID=your_payouts_app_id
CASHFREE_PAYOUTS_CLIENT_SECRET=your_payouts_secret
# Optional: defaults prod https://api.cashfree.com/payout | sandbox https://sandbox.cashfree.com/payout
# Do not use old payout-api.cashfree.com host for V2 paths.
# CASHFREE_PAYOUTS_BASE_URL=
# API date header for V2 (see Cashfree Payouts API reference if transfers fail with version errors)
# CASHFREE_PAYOUTS_API_VERSION=2024-01-01
# Withdrawals: POST /transfers — banktransfer|imps|neft|rtgs|upi (default banktransfer)
# CASHFREE_PAYOUTS_TRANSFER_MODE=banktransfer
# CASHFREE_PAYOUT_MIN_INR=100
# CASHFREE_PAYOUT_MAX_INR=100000
# Webhook URL for production: https://YOUR_HOST/api/cashfree/webhooks/payout (see docs/CASHFREE_PAYOUT_WEBHOOK.md)
# Optional: override secret used only for webhook HMAC (else CASHFREE_PAYOUTS_CLIENT_SECRET)
# CASHFREE_PAYOUT_WEBHOOK_SECRET=
# CASHFREE_PAYOUT_WEBHOOK_SKIP_VERIFY=1
# CASHFREE_PAYOUT_WEBHOOK_DEBUG=1   # logs body length + headers only (troubleshoot 401)

# Job post gate: one ChatGPT (JSON) call on title + description + category.
# Handles English, Hindi, Hinglish. Without OPENAI_API_KEY the gate is off (all posts allowed) unless you require it in ops.
# If logs show HTTP 429, OpenAI rate limits: upgrade tier, reduce traffic, or deploy latest backend (single call, no Moderation API).
OPENAI_API_KEY=
# OPENAI_JOB_CHAT_MODEL=gpt-4o-mini
# JOB_CHAT_GATE_ENABLED=true
# On OpenAI errors: true = allow post (dev only), false = show try again (default)
# JOB_CHAT_GATE_FAIL_OPEN=false

# SecureID / bank verification — base URL is api.cashfree.com/verification (prod) or sandbox.
# Prod keys ONLY work on prod host. If you omit CASHFREE_VRS_ENV, we use production when
# NODE_ENV=production OR CASHFREE_PAYOUTS_ENV=production (so Render matches your curl).
# For local testing with sandbox Cashfree keys, set: CASHFREE_VRS_ENV=sandbox
CASHFREE_VRS_ENV=production
# CASHFREE_VRS_CLIENT_ID=
# CASHFREE_VRS_CLIENT_SECRET=

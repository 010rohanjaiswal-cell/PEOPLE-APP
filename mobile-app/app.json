{
  "expo": {
    "name": "People",
    "slug": "mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./newicon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.company.people",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to show nearby jobs and to attach your location when posting a job.",
        "LSApplicationQueriesSchemes": [
          "ppemerchantsdkv1",
          "ppemerchantsdkv2",
          "ppemerchantsdkv3",
          "paytmmp",
          "gpay"
        ]
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.company.people",
      "googleServicesFile": "./google-services.json",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./newicon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "android": { "defaultChannel": "default" },
          "sounds": ["./assets/sounds/notification_sound.wav"]
        }
      ],
      "expo-location",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to upload profile pictures and documents.",
          "cameraPermission": "The app needs access to your camera to take photos."
        }
      ],
      "expo-font",
      "./plugins/withPhonePeMaven"
    ],
    "scheme": "people-app",
    "extra": {
      "eas": {
        "projectId": "d2c6e8f0-df10-48b6-8dc0-01909a34e866"
      }
    },
    "owner": "010rohan"
  }
}
